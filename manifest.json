{
  "manifest_version": 3,
  "name": "Pluzo Sites Cache",
  "version": "0.1.0",
  "description": "Diagnostica cache e consultas D1/Worker em sites publicos Pluzo.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Abrir Pluzo Cache",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "options_page": "src/options.html",
  "devtools_page": "src/devtools.html",
  "permissions": ["storage", "webRequest", "tabs", "scripting"],
  "host_permissions": ["https://pluzo.top/*", "https://pluzo.shop/*"],
  "optional_host_permissions": ["http://*/*", "https://*/*"]
}
